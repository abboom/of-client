{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": [
    "renderer_process/**/*",
    "renderer_process/**/*.vue",
    "types/env.d.ts",
    "types/auto-renderer-imports.d.ts",
    "types/components.d.ts",
    "types/vue.d.ts"
  ],
  "exclude": [
    "src/**/__tests__/*"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "paths": {
      "@/*": ["renderer_process/*"]
    }
  }
}
